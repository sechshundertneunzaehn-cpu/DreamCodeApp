# ============================================================
# DreamCode App — Environment Variables
# ============================================================
# VITE_* = wird ins Client-Bundle gebacken (Browser sieht diesen Wert)
# Ohne VITE_ = Server-only (Vercel Environment Variables, sicher)
# ============================================================

# ── CLIENT-SIDE (VITE_) ──────────────────────────────────────

# Supabase (aus Settings → API)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Mapbox (für wissenschaftliche Weltkarte — öffentlicher Token OK)
VITE_MAPBOX_TOKEN=pk.xxx...

# Ollama (lokaler LLM, optional)
VITE_OLLAMA_BASE_URL=http://localhost:11434

# Traumkarte-Sektion: Knowledge-Graph statt SVG-Weltkarten-Preview zeigen (default: aus)
VITE_ENABLE_GRAPH=false

# ── SERVER-ONLY (Vercel Environment Variables) ───────────────
# Diese Werte NIEMALS mit VITE_ Prefix setzen!
# In Vercel: Settings → Environment Variables → ohne VITE_ Prefix

# Supabase Service Role (für Server-Funktionen)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic / Claude (für /api/dream-analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (für /api/generate-text, /api/generate-image, /api/transcribe)
GEMINI_API_KEY=AIza...
GEMINI_API_KEY_2=AIza...
GEMINI_API_KEY_3=AIza...
GEMINI_API_KEY_4=AIza...

# Google Cloud TTS (für /api/tts)
GOOGLE_CLOUD_TTS_KEY=AIza...

# Groq (für /api/generate-text, /api/chat)
GROQ_API_KEY=gsk_...
GROQ_API_KEY_2=gsk_...
GROQ_API_KEY_3=gsk_...

# Mistral (für /api/chat Fallback)
MISTRAL_API_KEY=...

# DeepSeek (für /api/llm)
DEEPSEEK_API_KEY=sk-...

# OpenRouter (für /api/llm)
OPENROUTER_API_KEY=sk-or-...

# ElevenLabs TTS (für /api/elevenlabs-tts)
ELEVENLABS_API_KEY=...

# Deepgram (für /api/deepgram-tts, /api/deepgram-token)
DEEPGRAM_API_KEY=Token ...

# Runware (für /api/generate-image)
RUNWARE_API_KEY=...

# Stripe (für /api/create-checkout, /api/verify-session, /api/webhook)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
