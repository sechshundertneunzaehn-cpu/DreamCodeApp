# Android Release Signing — NICHT committen! Kopiere als keystore.properties
# Keystore generieren:
#   keytool -genkey -v -keystore dreamcode-release.keystore -alias dreamcode -keyalg RSA -keysize 2048 -validity 10000
storeFile=dreamcode-release.keystore
storePassword=DEIN_KEYSTORE_PASSWORT
keyAlias=dreamcode
keyPassword=DEIN_KEY_PASSWORT
