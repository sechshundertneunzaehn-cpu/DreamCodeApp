# ============================================================
# EduScraper — Environment Config
# Copy this file to .env and fill in your values
# ============================================================

# Redis connection
REDIS_URL=redis://localhost:6379

# Worker concurrency (parallel jobs)
CONCURRENCY=50

# Rate limit: max requests per second per domain
RATE_LIMIT_RPS=5

# Output file path (relative to project root)
OUTPUT_FILE=./output/results.csv

# Path to existing us_education_data directory
# (contains output/*.csv and simple_exports/*.csv)
DATA_DIR=/home/dejavu/Projects/DreamCode/research-study/us_education_data

# ============================================================
# Proxy Config (optional but recommended for large runs)
# ============================================================

# Proxies disabled by default — set to "true" to enable
PROXY_ENABLED=false

# Default / fallback proxy
# Format: http://user:password@host:port
PROXY_URL=

# IPRoyal / Bright Data residential proxies by region
# US proxy for US universities
PROXY_URL_US=

# EU proxy for European universities
PROXY_URL_EU=

# Asia/Pacific proxy
PROXY_URL_ASIA=

# ============================================================
# Telegram notifications (optional)
# ============================================================

# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=
